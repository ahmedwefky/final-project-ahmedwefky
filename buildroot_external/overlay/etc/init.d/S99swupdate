#!/bin/sh
#
# SWUpdate daemon startup script
#

NAME="swupdate"
DESC="Software Update Service"
DAEMON="/usr/bin/swupdate"
PIDFILE="/var/run/swupdate.pid"
LOGFILE="/var/log/swupdate.log"
CONFIG="/etc/swupdate.cfg"

# Ensure log directory exists
mkdir -p /var/log

start() {
    printf "%-50s" "Starting $DESC..."
    
    if [ ! -f "$CONFIG" ]; then
        echo "FAILED (config not found)"
        return 1
    fi
    
    # Start SWUpdate daemon in suricatta mode for automated updates
    # Use -C for configuration file
    # Use -v for verbose logging
    $DAEMON -C "$CONFIG" -v > "$LOGFILE" 2>&1 &
    
    echo $! > $PIDFILE
    echo "OK"
    return 0
}

stop() {
    printf "%-50s" "Stopping $DESC..."
    
    if [ -f "$PIDFILE" ]; then
        kill $(cat $PIDFILE) 2>/dev/null
        rm -f $PIDFILE
    fi
    
    echo "OK"
    return 0
}

restart() {
    stop
    sleep 1
    start
}

status() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat $PIDFILE)
        if kill -0 $PID 2>/dev/null; then
            echo "$DESC is running (PID $PID)"
            return 0
        fi
    fi
    echo "$DESC is not running"
    return 1
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart|reload)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload|status}"
        exit 1
        ;;
esac

exit $?
