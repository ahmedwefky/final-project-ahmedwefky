# fw_env.config - U-Boot environment access configuration
# This file tells fw_setenv/fw_getenv where to find U-Boot environment

# For Raspberry Pi 0 W with default U-Boot configuration:
# - Environment is stored in the second 64KB sector
# - Device: /dev/mmcblk0 (SD card)
# - Offset: 0x10000 (64KB)
# - Size: 0x4000 (16KB) - typical size

# Device name | Offset | Size | Sector size
/boot/uboot.env  0x0000  0x4000  0x4000
